# =============================================================================
# Corveon — Environment Configuration (example)
# Copy to `.env` and fill in. NEVER commit a real `.env`. See docs/ENVIRONMENT.md
# for the authoritative description of every variable.
#
# Golden rule (§11): all secrets come from the environment only — never code,
# never the database. Absent optional AI providers are a NORMAL state (§23.1),
# not an error: leave their keys blank and Corveon runs in degraded/local mode.
# =============================================================================

# ─── Core / runtime ─────────────────────────────────────────────────────────
CORVEON_ENV=development                 # development | test | staging | production
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                         # json (prod) | console (local dev)
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_ORIGIN=http://localhost:3000   # CORS allow-origin for the SPA

# ─── Security / auth (§11) ──────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-min-32-bytes-of-random   # openssl rand -hex 32
JWT_ACCESS_TTL_SECONDS=900              # 15 min short-lived access token
JWT_REFRESH_TTL_SECONDS=1209600         # 14 day refresh token
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=4

# ─── PostgreSQL 16 + pgvector (§10) ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://corveon:corveon@localhost:5432/corveon
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5
DB_ENABLE_RLS=true                      # Row-Level Security on chat_id/user_id

# ─── Redis — cache + ARQ queue (§12) ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
EXTERNAL_CACHE_DEFAULT_TTL_SECONDS=86400

# ─── Object storage — Cloudflare R2 (§10, §11) ──────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=corveon-documents
R2_ENDPOINT=                            # https://<account>.r2.cloudflarestorage.com
R2_SIGNED_URL_TTL_SECONDS=300           # short-lived signed links only
LOCAL_STORAGE_DIR=.data/documents      # dev/test fallback when R2 is unconfigured (ADR-0014)

# ─── Embeddings (§4, §23.4) ─────────────────────────────────────────────────
EMBEDDING_MODEL_ID=BAAI/bge-small-en-v1.5   # 384-dim; must match vector(384)
EMBEDDING_DEVICE=cpu

# ─── AI provider layer — ALL OPTIONAL (§5, §23.1) ───────────────────────────
# Leave a provider blank to disable it. Zero configured providers is valid:
# Corveon falls back to Ollama-local, or to degraded (non-LLM) mode.
# Comma-separated key pools enable rotation/failover (§5).
GEMINI_API_KEYS=                        # pool: key1,key2,...
GEMINI_DEFAULT_MODEL=gemini-2.5-flash-lite
ANTHROPIC_API_KEYS=
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-5
OPENAI_API_KEYS=
OPENAI_DEFAULT_MODEL=gpt-4.1-mini
OPENROUTER_API_KEYS=
OPENROUTER_DEFAULT_MODEL=
OLLAMA_BASE_URL=http://localhost:11434  # implicit local default when reachable
OLLAMA_DEFAULT_MODEL=llama3.1

# Provider priority order (comma-separated names, highest first). Router only
# ever considers registered ∧ healthy providers; policy names no concrete one.
PROVIDER_PRIORITY=gemini,openrouter,ollama
# Route org-trusted / sensitive text to local inference only (privacy policy).
SENSITIVE_TEXT_PROVIDER=ollama
# Per-request LLM call budget guarding fan-out vs free-tier RPM (§23.2).
LLM_CALLS_PER_REQUEST_BUDGET=8

# ─── External medical APIs (§8) — free; keys raise rate limits ──────────────
OPENFDA_API_KEY=                        # optional: 240/min + 120k/day with key
NCBI_EUTILS_API_KEY=                    # optional: 10 req/s with key, 3 without
NCBI_EUTILS_EMAIL=                      # NCBI requires a contact email
# RxNav is used for normalization only. The RxNav DDI API was discontinued
# 2024-01-02 — DDI data comes from DDInter 2.0 + openFDA (§9, ADR-0004).
RXNAV_BASE_URL=https://rxnav.nlm.nih.gov/REST
RXNAV_MAX_RPS=20

# ─── Observability (§16) ────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=            # e.g. http://localhost:4317
OTEL_SERVICE_NAME=corveon-api
PROMETHEUS_METRICS_ENABLED=true
SENTRY_DSN=                             # optional; blank disables Sentry

# ─── Frontend (Next.js — NEXT_PUBLIC_* are exposed to the browser) ──────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_SSE_BASE_URL=http://localhost:8000   # SSE served by backend, not Vercel (§23.3)
