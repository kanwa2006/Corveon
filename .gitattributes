# Normalize line endings to LF across platforms.
* text=auto eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.ico binary
*.woff binary
*.woff2 binary

# Generated / vendored — collapse in diffs.
pnpm-lock.yaml linguist-generated=true -diff
*.lock linguist-generated=true -diff
