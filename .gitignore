# =============================================================================
# Corveon .gitignore
# =============================================================================

# ─── Secrets & environment ──────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets/
credentials.json

# Local dev-tool launch config — commonly contains machine-specific absolute
# paths (e.g. a local venv location), not portable across machines/CI.
.claude/launch.json

# ─── Python / backend ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
wheels/
.installed.cfg
*.manifest
*.spec
.venv/
venv/
env/
.python-version
.mypy_cache/
.dmypy.json
.ruff_cache/
.pytest_cache/
.hypothesis/
.coverage
.coverage.*
coverage.xml
htmlcov/
nosetests.xml
.tox/
.nox/
cython_debug/

# ─── Node / frontend ────────────────────────────────────────────────────
node_modules/
.next/
next-env.d.ts
out/
.turbo/
*.tsbuildinfo
.eslintcache
.stylelintcache
.pnp.*
.yarn/*
!.yarn/patches
.pnpm-store/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
coverage/
.nyc_output/

# ─── Testing artifacts ──────────────────────────────────────────────────
playwright-report/
playwright/.cache/
blob-report/
test-results/

# ─── Data snapshots (pinned drug data is fetched, never committed) ───────
data/snapshots/
*.duckdb
*.sqlite
*.sqlite3

# ─── Infra / local services / Docker ────────────────────────────────────
pgdata/
redisdata/
ollama-data/
docker-compose.override.yml
*.log
logs/

# ─── Editors / IDEs ─────────────────────────────────────────────────────
.idea/
*.iml
*.ipr
*.iws
.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json
.fleet/
.zed/
*.sublime-project
*.sublime-workspace
*.code-workspace
.history/

# ─── OS cruft ───────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
desktop.ini
$RECYCLE.BIN/
*.lnk

# ─── Temp / backup / misc ───────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.orig
*.rej
*.swp
*.swo
*~
.cache/
tmp/
scratch/
